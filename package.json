{
  "name": "leminejs",
  "version": "0.0.0",
  "private": true,
  "description": "LemineJS monorepo: full-stack JSX framework with built-in widgets, routing, rendering, compiler, CLI, and Vite integration.",
  "packageManager": "pnpm@9.15.0",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --concurrency=20",
    "lemine": "node ./packages/cli/dist/index.js",
    "test": "turbo run test --parallel",
    "lint": "turbo run lint --parallel",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  }
}
