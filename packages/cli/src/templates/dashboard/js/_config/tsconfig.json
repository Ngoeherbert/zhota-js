{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "jsx": "react-jsx",
    "jsxImportSource": "@leminejs/core",
    "moduleResolution": "bundler",
    "module": "esnext",
    "target": "ES2020"
  },
  "include": [
    "**/*.js",
    "**/*.jsx"
  ],
  "exclude": [
    "node_modules",
    ".lemine"
  ]
}
