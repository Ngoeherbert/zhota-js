{
  "compilerOptions": {
    "strict": true,
    "checkJs": false,
    "jsx": "react-jsx",
    "jsxImportSource": "@leminejs/core",
    "moduleResolution": "bundler",
    "module": "esnext",
    "target": "ES2020"
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "lemine-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    ".lemine"
  ]
}
