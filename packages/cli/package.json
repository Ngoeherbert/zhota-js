{
  "name": "@leminejs/cli",
  "version": "0.0.0",
  "description": "LemineJS cli package.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "scripts",
    "assets"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node ./scripts/postbuild.cjs",
    "dev": "tsc -p tsconfig.json --watch",
    "lemine": "node ./dist/index.js",
    "test": "vitest run --passWithNoTests",
    "lint": "cd ../.. && eslint packages/cli/src packages/cli/tests packages/cli/vite.config.ts packages/cli/vitest.config.ts --ext .ts,.tsx --ignore-pattern 'packages/cli/src/templates/**'",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "sideEffects": false,
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "@leminejs/server": "workspace:^",
    "@leminejs/compiler": "workspace:^"
  },
  "bin": {
    "lemine": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  }
}
